# Keep the build context small and never ship host (macOS) node_modules into
# the linux image — npm ci rebuilds them inside the container.
node_modules
.next
out
coverage
.git
.github
.husky

# Local env / secrets — never bake into the image.
.env*

# Logs & misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Dockerfile
docker-compose.yml
.dockerignore

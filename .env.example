# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend)
RESEND_API_KEY=re_...
# From address. Requires a verified domain in Resend for sending to customers.
# Without domain verification only emails to your own Resend account address go through.
RESEND_FROM_EMAIL=onboarding@resend.dev

# SMS (Twilio) - add when ready
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# DVLA MOT History API - add when ready
DVLA_MOT_API_KEY=

# Cron job auth — set to a long random string, add to Vercel env vars too
CRON_SECRET=your-random-secret-here

# Stripe (Connect Express + Checkout pay-link on invoices)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Platform fee skimmed from every customer-to-garage payment, percent. Default 2.
STRIPE_PLATFORM_FEE_PERCENT=2

# Xero accounting (per-garage OAuth, app → Xero one-way sync)
# Create a Xero app at https://developer.xero.com/app/manage and add the
# callback URL: https://ai-garage.co.uk/api/xero/connect/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# App
# Use localtest.me for local dev: *.localtest.me resolves to 127.0.0.1
# without any DNS or hosts-file changes, so smith-motors.localtest.me:3000
# routes to your local dev server. In production set this to your real domain.
NEXT_PUBLIC_ROOT_DOMAIN=localtest.me:3000
